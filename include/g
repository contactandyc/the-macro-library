function drawRadio( $name, $fields, $method=null ) {
  $result = '<center>';
  foreach( $fields as $f ) {
    $df = $f;
    if(isset($method))
      $df = $method($f);
    $exists = false;
    if(isset($_GET[$name])) {
      if(is_array($_GET[$name]))
        $exists = in_array($f, $_GET[$name]);
      else {
        if($_GET[$name] == $f)
          $exists = true;
      }      
    }
    
    $result .= ' &nbsp; ' . $df . ' <INPUT TYPE="radio" name="' . $name . '" value="' . $f . '"' . ($exists ? " checked" : "") . '>';
  }
  $result .= '</center>
';
  return $result;

}

function drawSelect( $name, $fields, $method=null, $multiple=false, $size=null ) {
  if(!isset($size))
    $size=sizeof($fields);
  $result = '<select size="' . $size . '" name="' . $name . ($multiple ? "[]" : "") . '"' . ($multiple ? " multiple" : "") . '>
';
  foreach( $fields as $f ) {
    $df = $f;
    if(isset($method))
      $df = $method($f);
    $exists = false;
    if(isset($_GET[$name])) {
      if(is_array($_GET[$name]))
        $exists = in_array($f, $_GET[$name]);
      else {
        if($_GET[$name] == $f)
          $exists = true;
      }      
    }
    $result .= '<OPTION value="' . $f . '"' . ($exists ? "selected" : "") . '>' . $df . '</OPTION>
';
  }
  $result .= '</SELECT>
';
  return $result;
}


