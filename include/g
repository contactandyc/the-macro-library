function _getWeek($startDate, $diff) {
  $date = $startDate->makeClone();
  $date->addDays($diff);
  
  $arr = $_GET;
  $arr['startDate'] = $date->getDateString();
  return 'goethe.php?' . http_build_query($arr);
}

