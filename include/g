function computeWeeklyGoal($col, $arr=null) {
  $tbl = $col->getTable();
  $tbl->setValue('weeklyGoal', 1);  
  $startDate = $tbl->getValue("startDate");
  $date = Homework::deriveStartDate($startDate);
  $studentIDs = $tbl->getRowIDsAsString();
  if(!isset($studentIDs)) return null;

  $query = "select userID,week,topicID,rating,numTopics,numMastered,pctComplete,engagedTime,newEngagedTime,betaTime,method,numRight,numProblems,numWorksheets,points,expectedEngagedTime,bonusStars from weeklyGoal where userID in (" . $studentIDs . ") and week=\"" . $date->getDateString() . '"';
  $result = Environment::dbQuery($query);
  if (!$result) {
    ALSC\Error::dbError($query, true);
    return NULL;
  }
  while ($row = mysqli_fetch_array($result)) {    
    $r = $tbl->getRowByID($row['userID']);
    $r->setValue('weeklyGoal', $row);
  }
}

function computeStars($col) {  
  $g = $col->getTableValue('weeklyGoal');
  if(!isset($g)) {
    computeWeeklyGoal($col);
    $col->setTableValue('weeklyGoal', 1);
  }

  $timeMethod = $col->getTableValue('timeMethod');
  $row = $col->getRowValue('weeklyGoal');
  $maxValue = $col->getColumnValue('maxValue');
  $result = 0.0;
  if(isset($row))
    $result = Homework::computeStars($row, $timeMethod);
  if(isset($maxValue) and $result > $maxValue)
    return $maxValue;
  return $result;
}


