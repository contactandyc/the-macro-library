function computeStudents($col, $arr=null) {
  $tbl = $col->getTable();
  $tbl->setValue('students', 1);  
  $students = $tbl->getRowIDs();
  if(!isset($students)) return null;
  
  $userNames = Student::getManyFromDatabase($students);
  foreach($userNames as $us) {
    $r = $tbl->getRowByID($us->mUserID);
    $r->setValue('students', $us);
  }
}

function computeStudentGrade($col) {
  $g = $col->getTableValue('students');
  if(!isset($g)) {
    computeStudents($col);
    $col->setTableValue('students', 1);
  }

  $startDate = $col->getTableValue('startDate');
  $row = $col->getRowValue('students');
  if(isset($row))
    return $row->getGrade($startDate->getDatetimeString());
  return 0;
}

